# Copy this file to .env and fill in the required values

# --- Inference Server & Model Config ---
# For local dev fallback: https://router.huggingface.co/v1 or local vLLM port
# For Modal deployment: https://<your-username>--exact-qwen3-8b-lora-exactmodel-api-server.modal.run/v1
VLLM_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=fol_router

# --- API Keys & Tokens ---
# Hugging Face token for downloading models and authorization
HF_API_KEY=
FOLC_AT=

# Optional: Weights & Biases API key for model tuning tracking
WANDB_API_KEY=

# Optional: Google Gemini API key for fallback logic checks
GEMINI_API_KEY=

# --- Modal Deployment Config ---
# Tokens for Modal deployment (typically set up via modal setup, but can be set here)
MODAL_KEY=
MODAL_SECRET=